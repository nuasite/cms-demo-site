---
interface Props {
	title?: string
}
const { title } = Astro.props
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title ?? 'CMS Demo Site'}</title>
		<style is:global>
			body { font-family: system-ui, sans-serif; line-height: 1.6; color: #1a1a1a; }
			main { max-width: 820px; margin: 2rem auto; padding: 0 1rem; }
			a { color: #2563eb; }
			img { max-width: 100%; height: auto; border-radius: 8px; }
			.card { border: 1px solid #e5e7eb; border-radius: 10px; padding: 1rem; margin: 0.75rem 0; }
		</style>
	</head>
	<body>
		<main>
			<slot />
		</main>
	</body>
</html>
