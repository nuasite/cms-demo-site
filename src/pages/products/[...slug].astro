---
import { getCollection } from 'astro:content'
import Base from '../../layouts/Base.astro'

export async function getStaticPaths() {
	const products = await getCollection('product')
	return products.map((product) => ({ params: { slug: product.id }, props: { product } }))
}

const { product } = Astro.props
const { data } = product
---

<Base title={data.title}>
	<p><a href="/">← Home</a></p>
	<h1>{data.title}</h1>
	{data.price != null && <p><strong>€{data.price}</strong>{data.salePrice != null && <span> (sale €{data.salePrice})</span>}</p>}
	{data.summary && <p>{data.summary}</p>}
	{data.description && <p>{data.description}</p>}
	{Array.isArray(data.specs) && data.specs.length > 0 && (
		<ul>
			{data.specs.map((spec) => <li><strong>{spec.label}:</strong> {spec.value}</li>)}
		</ul>
	)}
</Base>
