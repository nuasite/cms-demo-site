---
import { getCollection } from 'astro:content'
import { Image } from '@nuasite/components'
import Base from '../layouts/Base.astro'

// Generic site pages from the `page` collection, one page per entry at the root
// (e.g. /about, /contact). More specific routes (blog, products, faq) win first.
export async function getStaticPaths() {
	const pages = await getCollection('page')
	// `page.id` includes the file extension (Astro 4) — strip it so the URL is `/<slug>`.
	return pages.map((page) => ({ params: { slug: page.id.replace(/\.(md|mdx)$/, '') }, props: { page } }))
}

const { page } = Astro.props
const { Content } = await page.render()
---

<Base title={page.data.title}>
	<p><a href="/">← Home</a></p>
	<h1>{page.data.title}</h1>
	{page.data.heroImage && <Image src={page.data.heroImage} alt={page.data.title} widths={[480, 820, 1200]} sizes="(min-width: 840px) 820px, 100vw" />}
	<Content />
</Base>
